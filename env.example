# Copy to the repository root as `.env` and fill every value.
# Hardhat loads `../../.env` (repo root) then `packages/hardhat/.env` (overrides).
# Next.js (packages/AgoraFrontEnd/next.config.mjs loads this file, then `.env.local` overrides)

# -----------------------------------------------------------------------------
# Circle Arc — testnet only (mainnet not live yet)
# -----------------------------------------------------------------------------
# Public RPC: https://docs.arc.network/arc/references/rpc-endpoints
# Chain ID: 5042002 (0x4cef52)
ARC_TESTNET_RPC_URL=https://arc-testnet.g.alchemy.com/v2/YOUR_KEY

# -----------------------------------------------------------------------------
# Contract verification (`yarn verify`) — Etherscan API v2 (chainid in request)
# -----------------------------------------------------------------------------
ETHERSCAN_V2_API_KEY=

# Deployer / scripted deploys (0x + 64 hex chars)
DEPLOYER_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Next.js — must be prefixed with NEXT_PUBLIC_ to reach the browser
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WALLET_CONNECT_PROJECT_ID=
NEXT_PUBLIC_ARC_TESTNET_RPC_URL=https://arc-testnet.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8001

# -----------------------------------------------------------------------------
# Python backend (reads repo root `.env`)
# -----------------------------------------------------------------------------
GCS_BUCKET=agora-market-data
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
RPC_URL=https://arc-testnet.g.alchemy.com/v2/YOUR_KEY
MANAGER_ADDRESS=
EXCHANGE_ADDRESS=
FORWARDER_ADDRESS=
FACTORY_ADDRESS=
RELAYER_PRIVATE_KEY=
RESOLVER_PRIVATE_KEY=
FACTORY_OWNER_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Collateral token (USDC) — Circle Arc testnet
# -----------------------------------------------------------------------------
# Leave blank to use the canonical Circle USDC at
#   0x3600000000000000000000000000000000000000
# (see https://docs.arc.network/arc/references/contract-addresses).
# Override here only if you intentionally want to point at a different ERC-20.
USDC_ADDRESS=

# -----------------------------------------------------------------------------
# Testnet wallet sandbox (max 6 wallets) — fund each with testnet USDC from
# https://faucet.circle.com (Arc testnet). On Arc, USDC is also the gas token.
# -----------------------------------------------------------------------------
TEST_WALLET_1_ADDRESS=
TEST_WALLET_2_ADDRESS=
TEST_WALLET_3_ADDRESS=
TEST_WALLET_4_ADDRESS=
TEST_WALLET_5_ADDRESS=
TEST_WALLET_6_ADDRESS=
TEST_WALLET_1_PRIVATE_KEY=
TEST_WALLET_2_PRIVATE_KEY=
TEST_WALLET_3_PRIVATE_KEY=
TEST_WALLET_4_PRIVATE_KEY=
TEST_WALLET_5_PRIVATE_KEY=
TEST_WALLET_6_PRIVATE_KEY=
